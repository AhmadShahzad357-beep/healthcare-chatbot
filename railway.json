{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "python -c \"import scripts.seed_database; scripts.seed_database.seed_database()\" && uvicorn api:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/patients",
    "restartPolicy": "on-failure",
    "restartPolicyMaxRetries": 10
  }
}
